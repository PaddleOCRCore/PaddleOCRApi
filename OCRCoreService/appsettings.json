{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "ApiAuth": {
    "enabled": false, //是否启用API认证鉴权
    "header_name": "PaddleOCR-Api-Key", //API Key请求头名称
    "api_key": "DiAFaGJT5SW3yw68Lfrn" //API Key密钥，启用认证后必须配置
  },
  "OCRConfig": {
    "det_infer": "PP-OCRv6_tiny_det_infer", // 文本检测模型推理路径
    "rec_infer": "PP-OCRv6_tiny_rec_infer", // 文本识别模型推理路径
    "cls_infer": "PP-LCNet_x1_0_textline_ori",
    "use_cls": true, //方向分类器
    "use_gpu": false,
    "enable_mkldnn": true, //是否启用CPU加速
    "use_tensorrt": false, //使用GPU预测时，是否启动tensorrt
    "gpu_id": 0,
    "gpu_mem": 4000,
    "cpu_mem": 0,
    "cpu_threads": 30,
    "rec_batch_num": 7,
    "enableLog": true,
    "visualize": false, // 是否输出可视化结果图
    "return_word_box": false, //是否启用单字坐标
    "ocr_instance_count": 1, //OCR引擎实例数量，默认1，最大10，适用于高并发时使用。
    "OCRLicense": "models/paddleocr.lic" //GPU授权文件路径，存在时初始化前自动激活
  },
  "LayoutConfig": {
    "det_infer": "PP-OCRv6_tiny_det_infer", // 文本检测模型推理路径
    "rec_infer": "PP-OCRv6_tiny_rec_infer", // 文本识别模型推理路径
    "cls_infer": "PP-LCNet_x1_0_textline_ori", // 方向分类器模型推理路径
    "doc_cls_infer": "PP-LCNet_x1_0_doc_ori_infer", // 文档方向分类模型推理路径（用于文档预处理）
    "layout_model_dir": "PP-DocLayout_plus-L", // 版面分析模型目录（支持20类文档元素检测，可替换为PP-DocLayout_plus-L）
    "table_cls_model_dir": "PP-LCNet_x1_0_table_cls_infer", // 表格有线/无线分类模型目录路径
    "wired_table_model_dir": "SLANeXt_wired_infer", // 有线表格结构识别模型路径
    "wireless_table_model_dir": "SLANeXt_wireless_infer", // 无线表格结构识别模型路径
    "wired_table_cell_det_model_dir": "RT-DETR-L_wired_table_cell_det_infer", // 有线表格单元格检测模型路径
    "wireless_table_cell_det_model_dir": "RT-DETR-L_wireless_table_cell_det_infer", // 无线表格单元格检测模型路径
    "formula_model_dir": "LaTeX_OCR_rec_infer", // 公式识别模型目录（输出LaTeX格式）
    "seal_model_dir": "PP-OCRv4_mobile_seal_det_infer", // 印章检测模型目录
    "doc_unwarp_model": "UVDoc_infer", // 文档图像矫正模型目录（去畸变/展平）
    "region_model_dir": "PP-DocBlockLayout", // PaddleX RegionDetection大区块检测模型目录（试卷场景的版面子模块检测）
    "use_gpu": false, // 是否使用GPU推理；false时走CPU
    "enable_mkldnn": true, // CPU场景是否启用MKLDNN加速
    "use_tensorrt": false, // 是否启用TensorRT加速（通常需GPU）
    "gpu_id": 0, // GPU设备编号（use_gpu=true时生效）
    "gpu_mem": 4000, // GPU显存上限（MB，供推理引擎分配参考）
    "cpu_mem": 0, // CPU内存阈值（MB，0表示不限制）
    "cpu_threads": 30, // CPU推理线程数
    "use_doc_preprocessor": true, // 是否启用文档预处理总开关
    "use_doc_orientation_classify": true, // 文档方向分类开关（0/90/180/270度）
    "use_doc_unwarping": false, // 文档去畸变/展平开关
    "use_layout_detection": true, // 是否执行版面检测；false时不产出版面框
    "use_region_detection": false, // 是否执行PaddleX RegionDetection大区块检测（试卷场景的版面子模块检测）
    "layout_nms": true, // 版面框后处理NMS（非极大值抑制）开关
    "layout_unclip_ratio_w": 1.0, // 版面框宽度扩张系数（边界框宽度扩展比例）
    "layout_unclip_ratio_h": 1.0, // 版面框高度扩张系数（边界框高度扩展比例）
    "run_ocr_after_layout": true, // 版面分析后是否执行OCR
    "text_det_thresh": 0.3, // OCR检测阈值（越高召回越低、精度通常更高，范围0-1）
    "text_rec_score_thresh": 0.5, // OCR识别分数阈值（低于该值的文本会被过滤，范围0-1）
    "use_textline_orientation": true, // 文本行方向分类开关
    "max_side_len": 960, // OCR检测缩放最大长边限制（输入图像最长边限制）
    "use_table_recognition": true, // 是否启用表格结构识别（输出HTML结构化表格）
    "use_table_cells_detection": true, // 是否启用表格单元格检测和按单元格OCR
    "use_seal_recognition": true, // 是否启用印章识别（输出印文内容和印章类型）
    "use_formula_recognition": true, // 是否启用公式识别（输出LaTeX格式公式）
    "format_block_content": false, // block_content是否按可读格式输出
    "output_markdown": true, // 是否在DetectLayout返回的JSON中附带markdown字段
    "enableLog": true,
    "visualize": false // 是否输出可视化结果图
  },
  "UVDocConfig": {
    "enabled": false, //是否启用UVDoc文档矫正服务
    "uvdoc_infer": "UVDoc_infer", //UVDoc模型
    "enable_mkldnn": true, //CPU模式下，是否使用mkldnn库
    "cpu_threads": 10, //CPU模式下，预测时的线程数
    "use_gpu": false, //是否使用GPU
    "gpu_id": 0, //GPU id，使用GPU时有效
    "gpu_mem": 2000, //使用GPU时内存
    "use_tensorrt": false //使用GPU预测时，是否启动tensorrt
  },
  "OCRVLConfig": {
    "enabled": true, //是否启用OCR-VL服务
    "yaml_path": "configs/PaddleOCR-VL-1.6.yaml" //yaml配置文件路径
  }
}
