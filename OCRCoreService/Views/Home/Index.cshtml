@{
    ViewData["Title"] = "PaddleOCRApi Demo";
    string ocrVlModelName = ViewData["OcrVlModelName"] as string ?? "PaddleOCR-VL-1.6";
    string ocrVlModelValue = ViewData["OcrVlModelValue"] as string ?? "paddleocr-vl-1.6";
}

<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="@Url.Content("~/css/home-index.css")">
</head>
<body>
    <main class="app" id="app">
        <header class="topbar">
            <div class="brand">
                <div class="brand-mark">P</div>
                <strong>飞桨</strong>
                <span>PaddleOCRApi</span>
            </div>
            <div class="license-actions">
                <button class="topbar-button" id="licenseCodeButton" type="button" data-tone="code" data-icon="码" title="获取授权申请码">获取授权申请码</button>
                <button class="topbar-button" id="licenseStatusButton" type="button" data-tone="status" data-icon="态" title="查看授权状态">查看授权状态</button>
                <button class="topbar-button" id="uploadLicenseButton" type="button" data-tone="upload" data-icon="传" title="上传授权文件">上传授权文件</button>
                <input id="licenseInput" type="file" accept=".lic" hidden>
            </div>
            <div class="status-pill" id="statusPill">加群：475159576</div>
        </header>

        <section class="workspace">
            <aside class="sidebar">
                <button class="new-button" id="newButton" type="button">＋ 新解析</button>
                <a class="api-button" href="/scalar">API接口</a>
                <div class="side-section">
                    <div class="side-title">
                        <span>上传列表</span>
                    </div>
                    <div class="file-list" id="fileList">
                        <div class="empty-list">没有更多啦</div>
                    </div>
                </div>
            </aside>

            <section class="preview-pane">
                <div class="upload-strip">
                    <label class="dropzone" id="dropzone">
                        <input id="fileInput" type="file" accept=".pdf,.png,.jpg,.jpeg,.bmp,.tif,.tiff,image/png,image/jpeg,image/bmp,image/tiff,application/pdf">
                        <span class="drop-content">
                            <span class="upload-icon">↑</span>
                            <span class="drop-title">点击上传或拖入文件开始解析</span>
                            <span class="drop-note">支持PDF/PNG/JPG/BMP/TIF等各种图片格式<br>单文件≤200MB&1000页，单图片≤10MB</span>
                        </span>
                    </label>

                    <div class="source-bar">
                        <div class="source-tab">源文件</div>
                        <div class="source-file" id="sourceName">未选择文件</div>
                        <div class="source-size" id="sourceSize"></div>
                    </div>
                </div>

                <div class="preview-stage">
                    <div class="image-shell">
                        <div class="placeholder" id="placeholder">
                            <div class="placeholder-mark">DOC</div>
                            <div>上传文件后在此预览解析区域</div>
                        </div>
                        <div class="image-wrap" id="imageWrap" hidden>
                            <img id="previewImage" alt="源文件预览">
                            <div class="overlay" id="overlay"></div>
                        </div>
                    </div>
                    <div class="pager" id="pager" hidden>
                        <button type="button" id="prevPageButton" title="上一页">‹</button>
                        <input class="page-input" id="pageInput" value="1" aria-label="页码">
                        <span>/</span>
                        <span id="pageCount">1</span>
                        <button type="button" id="nextPageButton" title="下一页">›</button>
                    </div>
                </div>
            </section>

            <section class="result-pane">
                <div class="model-row">
                    <label class="model-label" for="modelSelect">解析模型</label>
                    <select class="model-select" id="modelSelect">
                        <option value="pp-structure">PP-StructureV3</option>
                        <option value="pp-ocrv6">PP-OCRv6</option>
                        <option value="@ocrVlModelValue">@ocrVlModelName</option>
                    </select>
                </div>

                <div class="tabbar">
                    <button class="tab active" id="docTab" type="button">▤ 文档解析</button>
                    <button class="tab" id="jsonTab" type="button">{ } JSON</button>
                    <div class="toolbar">
                        <button class="icon-button" id="copyButton" type="button" title="复制">⧉</button>
                        <button class="icon-button" id="refreshButton" type="button" title="重新解析">↻</button>
                    </div>
                </div>

                <div class="result-body">
                    <div class="result-content plain-text" id="docView">等待上传文件</div>
                    <pre class="json-view" id="jsonView">{}</pre>
                </div>
            </section>
        </section>
    </main>

    <div class="toast" id="toast"></div>

    <script src="@Url.Content("~/js/home-mathjax-config.js")"></script>
    <script src="@Url.Content("~/js/tex-mml-chtml.js")"></script>
    <script src="@Url.Content("~/js/marked.min.js")"></script>
    <script src="@Url.Content("~/js/home-index.js")"></script>
</body>
</html>
